{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Bim360User",
  "title": "Bim360User",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "account_id": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "uid": {
      "type": "string"
    },
    "image_url": {
      "type": "string",
      "format": "uri"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "pending"
      ]
    },
    "company_id": {
      "type": "string"
    },
    "company_name": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "industry_roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}