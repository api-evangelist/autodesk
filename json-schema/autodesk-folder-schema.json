{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Folder",
  "title": "Folder",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "example": "folders"
    },
    "id": {
      "type": "string"
    },
    "attributes": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "createTime": {
          "type": "string",
          "format": "date-time"
        },
        "createUserId": {
          "type": "string"
        },
        "createUserName": {
          "type": "string"
        },
        "lastModifiedTime": {
          "type": "string",
          "format": "date-time"
        },
        "lastModifiedUserId": {
          "type": "string"
        },
        "lastModifiedUserName": {
          "type": "string"
        },
        "objectCount": {
          "type": "integer"
        },
        "extension": {
          "$ref": "#/components/schemas/Extension"
        },
        "hidden": {
          "type": "boolean"
        }
      }
    }
  }
}