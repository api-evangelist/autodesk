{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/AppBundlePayload",
  "title": "AppBundlePayload",
  "type": "object",
  "required": [
    "id",
    "engine"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "The AppBundle name."
    },
    "engine": {
      "type": "string",
      "description": "The target engine (e.g., Autodesk.AutoCAD+24_1)."
    },
    "description": {
      "type": "string"
    },
    "appbundles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}