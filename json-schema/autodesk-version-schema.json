{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Version",
  "title": "Version",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "example": "versions"
    },
    "id": {
      "type": "string"
    },
    "attributes": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "versionNumber": {
          "type": "integer"
        },
        "mimeType": {
          "type": "string"
        },
        "fileType": {
          "type": "string"
        },
        "storageSize": {
          "type": "integer"
        },
        "createTime": {
          "type": "string",
          "format": "date-time"
        },
        "createUserId": {
          "type": "string"
        },
        "createUserName": {
          "type": "string"
        },
        "lastModifiedTime": {
          "type": "string",
          "format": "date-time"
        },
        "lastModifiedUserId": {
          "type": "string"
        },
        "lastModifiedUserName": {
          "type": "string"
        },
        "extension": {
          "$ref": "#/components/schemas/Extension"
        }
      }
    }
  }
}