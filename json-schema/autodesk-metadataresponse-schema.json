{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/MetadataResponse",
  "title": "MetadataResponse",
  "type": "object",
  "properties": {
    "data": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "example": "metadata"
        },
        "metadata": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "guid": {
                "type": "string"
              },
              "role": {
                "type": "string",
                "enum": [
                  "3d",
                  "2d"
                ]
              },
              "isMasterView": {
                "type": "boolean"
              }
            }
          }
        }
      }
    }
  }
}