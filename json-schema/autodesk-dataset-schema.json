{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Dataset",
  "title": "Dataset",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "electricity",
        "material",
        "transportation",
        "construction"
      ]
    },
    "provider": {
      "type": "string",
      "description": "Data provider name."
    },
    "version": {
      "type": "string"
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    }
  }
}