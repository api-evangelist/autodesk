    "name": "Autodesk Flow Graph Engine API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Flow Graph Engine API enables evaluation of Bifrost graphs in the cloud for media and entertainment workflows. It allows developers to offload heavy processing tasks like creating complex effects, simulations, and procedural content to concurrent cloud operations using Bifrost graph evaluation engine.\n\nContact Support:\n Name: Autodesk Platform Services\n Email: aps.help@autodesk.com",
      "type": "text/plain"
    }
  }
