          "id": "13d458bc-bd87-4eea-91c5-d44e2dd846b5",
          "name": "Autodesk Authorize User",
          "request": {
            "name": "Autodesk Authorize User",
            "description": {
              "content": "Redirects the user to the Autodesk login page where they grant your application access to their data. This is the first step of the three-legged OAuth flow. After the user grants consent, Autodesk redirects them back to the redirect URI with an authorization code.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "authentication",
                "v2",
                "authorize"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "response_type",
                  "value": "<string>",
                  "description": "(Required) Must be set to `code` for authorization code flow."
                },
                {
                  "disabled": false,
                  "key": "client_id",
                  "value": "<string>",
                  "description": "(Required) The Client ID of your APS application."
                },
                {
                  "disabled": false,
                  "key": "redirect_uri",
                  "value": "<uri>",
                  "description": "(Required) The URI that Autodesk redirects the user to after granting consent. Must match a redirect URI registered with the application."
                },
                {
                  "disabled": false,
                  "key": "scope",
                  "value": "<string>",
                  "description": "(Required) Space-separated list of scopes requested. Common scopes include data:read, data:write, data:create, account:read, account:write."
                },
                {
                  "disabled": false,
                  "key": "state",
                  "value": "<string>",
                  "description": "An opaque value that the application uses to maintain state between the request and callback. Used to prevent CSRF attacks."
                },
                {
                  "disabled": false,
                  "key": "nonce",
                  "value": "<string>",
                  "description": "A random string used to associate a client session with an ID token."
                },
                {
                  "disabled": false,
                  "key": "prompt",
                  "value": "<string>",
                  "description": "Controls the authentication experience presented to the user."
                }
              ],
              "variable": []
            },
            "method": "GET",
            "auth": null
          },
          "response": [
